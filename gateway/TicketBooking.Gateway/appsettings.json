{
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "TicketBooking",
    "Audience": "TicketBookingClient"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*:/api/auth/*",
        "Period": "1m",
        "Limit": 20
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "user-service",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "user-service",
        "Match": { "Path": "/api/users/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "events-route": {
        "ClusterId": "event-service",
        "Match": { "Path": "/api/events/{**catch-all}" }
      },
      "bookings-route": {
        "ClusterId": "booking-service",
        "Match": { "Path": "/api/bookings/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "payments-route": {
        "ClusterId": "payment-service",
        "Match": { "Path": "/api/payments/{**catch-all}" },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "user-service": {
        "Destinations": {
          "user-service/1": { "Address": "http://user-service:8080" }
        }
      },
      "event-service": {
        "Destinations": {
          "event-service/1": { "Address": "http://event-service:8080" }
        }
      },
      "booking-service": {
        "Destinations": {
          "booking-service/1": { "Address": "http://nginx-lb:80" }
        }
      },
      "payment-service": {
        "Destinations": {
          "payment-service/1": { "Address": "http://payment-service:8080" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

