{
  "ConnectionStrings": {
    "BookingDb": "Host=postgres-bookings;Port=5432;Database=bookings_db;Username=postgres;Password=${POSTGRES_PASSWORD}",
    "Redis": "redis:6379"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "TicketBooking",
    "Audience": "TicketBookingClient"
  },
  "RabbitMq": {
    "Host": "rabbitmq",
    "Port": "5672",
    "Username": "guest",
    "Password": "guest"
  },
  "Services": {
    "EventService": "http://event-service:8080"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
