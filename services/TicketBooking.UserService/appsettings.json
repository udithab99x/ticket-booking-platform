{
  "ConnectionStrings": {
    "UserDb": "Host=postgres-users;Port=5432;Database=users_db;Username=postgres;Password=${POSTGRES_PASSWORD}"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "TicketBooking",
    "Audience": "TicketBookingClient",
    "ExpiryHours": "24"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
